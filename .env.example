DB_NAME=stream_db
DB_USER=stream_user
DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-me
NMS_SECRET_KEY=change-this-secret
ADMIN_PASSWORD=change-admin-password
NMS_API_USER=
NMS_API_PASS=
SV388_PROXY_SERVER=
SV388_PROXY_USERNAME=
SV388_PROXY_PASSWORD=

# file = phat video co san tren VPS thanh HLS. rtmp = nhan nguon RTMP/OBS nhu cu.
STREAM_SOURCE=file
# Co the tro vao mot file (/videos/live.mp4) hoac ca thu muc (/videos)
SOURCE_VIDEO_PATH=/videos
SOURCE_VIDEO_EXTENSIONS=.mp4,.mov,.m4v,.mkv,.webm
HLS_STREAM_NAME=main
STREAM_LOOP=1
STREAM_REALTIME=1
FILE_HLS_RESTART=1

SITE_URL=https://your-domain.com
PUBLIC_API_URL=https://api.your-domain.com
VITE_STREAM_FORMAT=hls
VITE_EMBED_URL=

WEB_PORT=80
API_PORT=8001
RTMP_PORT=1935
NMS_HTTP_PORT=8000
