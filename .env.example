DB_NAME=stream_db
DB_USER=stream_user
DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-me
NMS_SECRET_KEY=change-this-secret

# file = phat video co san tren VPS thanh HLS. rtmp = nhan nguon RTMP/OBS nhu cu.
STREAM_SOURCE=file
SOURCE_VIDEO_PATH=/videos/live.mp4
HLS_STREAM_NAME=obs_stream
STREAM_LOOP=1
STREAM_REALTIME=1
FILE_HLS_RESTART=1

SITE_URL=https://your-domain.com
PUBLIC_API_URL=https://api.your-domain.com
VITE_STREAM_FORMAT=hls

WEB_PORT=80
API_PORT=8001
RTMP_PORT=1935
NMS_HTTP_PORT=8000
